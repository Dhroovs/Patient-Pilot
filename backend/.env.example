# PatientPilot Backend Configuration Example

# Server configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Google Gemini API (Required for AI analysis and Chatbot)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Database configuration (Optional, falls back to local JSON database if empty or offline)
MONGO_URI=

# Google Vision API (Optional, falls back to local Tesseract OCR if empty or offline)
VISION_API_KEY=
